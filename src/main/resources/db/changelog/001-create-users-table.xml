<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
  http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

  <changeSet id="001-create-users-table" author="sharad">
    <comment>Creating users table</comment>

    <createTable tableName="user">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      
      <column name="name" type="varchar(255)">
        <constraints nullable="false"/>
      </column>
      
      <column name="email" type="varchar(255)">
        <constraints nullable="false" unique="true"/>
      </column>
      
      <column name="phone" type="varchar(20)"/>
              
      <column name="pan_number" type="varchar(20)"/>
        <constraints unique="true"/>
      </column>

      <column name="razorpay_customer_id" type="varchar(255)"/>
       <constraints unique="true"/>
      </column>

      <column name="bank_account_verified" type="boolean" defaultValueBoolean="false"/>
      <column name="kyc_status" type="varchar(20)"/>
      <column name="created_at" type="timestamp"/>
      <column name="updated_at" type="timestamp"/>
    </createTable>
  </changeSet>
</databaseChangeLog>