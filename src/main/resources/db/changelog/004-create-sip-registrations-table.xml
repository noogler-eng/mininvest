<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="004-create-sip-registrations-table" author="sharad">
        <comment>Create sip_registrations table for recurring investment mandates</comment>
        
        <createTable tableName="sip_registrations">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="bigint">
                <constraints nullable="false" 
                             foreignKeyName="fk_sip_user" 
                             referencedTableName="user" 
                             referencedColumnNames="id"/>
            </column>

            <column name="scheme_name" type="varchar(255)"/>

            <column name="amount" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="sip_date" type="integer">
                <constraints nullable="false"/>
            </column>

            <column name="start_date" type="varchar(7)">
                <constraints nullable="false"/>
            </column>

            <column name="mandate_order_id" type="varchar(50)"/>
            <column name="mandate_token_id" type="varchar(50)"/>

            <column name="mandate_status" type="varchar(30)"/>
            
            <column name="sip_status" type="varchar(30)">
                <constraints nullable="false"/>
            </column>

            <column name="completed_installments" type="integer" defaultValueNumeric="0"/>

            <column name="created_at" type="timestamp"/>
            <column name="updated_at" type="timestamp"/>
        </createTable>
    </changeSet>

</databaseChangeLog>