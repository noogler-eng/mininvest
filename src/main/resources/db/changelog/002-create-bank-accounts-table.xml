<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="002-create-bank-accounts-table" author="sharad">
        <comment>Create bank_accounts table with relationship to user</comment>
        
        <createTable tableName="bank_accounts">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="bigint">
                <constraints nullable="false" 
                             foreignKeyName="fk_bankaccount_user" 
                             referencedTableName="user" 
                             referencedColumnNames="id"/>
            </column>

            <column name="account_number" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <column name="ifsc" type="varchar(11)">
                <constraints nullable="false"/>
            </column>

            <column name="bank_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <column name="account_holder_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <column name="verified" type="boolean" defaultValueBoolean="false"/>

            <column name="primary_account" type="boolean" defaultValueBoolean="false"/>
        </createTable>
    </changeSet>

</databaseChangeLog>